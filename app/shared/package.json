{
  "name": "@blueprint/shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    },
    "./aws": {
      "import": "./dist/aws/index.js",
      "types": "./dist/aws/index.d.ts"
    },
    "./tracing": {
      "import": "./dist/tracing/index.js",
      "types": "./dist/tracing/index.d.ts"
    },
    "./resilience": {
      "import": "./dist/resilience/circuit-breaker.js",
      "types": "./dist/resilience/circuit-breaker.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1014.0",
    "@aws-sdk/client-dynamodb": "^3.1014.0",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/client-secrets-manager": "^3.1014.0",
    "@aws-sdk/client-sns": "^3.1014.0",
    "@aws-sdk/client-sqs": "^3.1014.0",
    "@aws-sdk/lib-dynamodb": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/id-generator-aws-xray": "^2.1.0",
    "@opentelemetry/propagator-aws-xray": "^2.2.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "ioredis": "^5.10.1",
    "opossum": "^9.0.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.20.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "opossum": "^9.0.0"
  }
}
